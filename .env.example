# Copy to .env and fill in. Never commit your real .env.

# Which LLM backend to use: "gemini" (default, free tier) or "ollama" (fully local).
LLM_PROVIDER=gemini

# --- Gemini (Google AI Studio free tier; no billing required) ---
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Ollama (local fallback; no API key needed) ---
# Install from https://ollama.com, then: ollama pull qwen2.5
OLLAMA_MODEL=qwen2.5
OLLAMA_BASE_URL=http://localhost:11434

# Shared LLM settings
LLM_TEMPERATURE=0.0
